# Copy this file to .env and fill in your own Supabase values.

# 1) Project URL (Dashboard > Project Settings > API > Project URL)
VITE_SUPABASE_URL=

# 2) Public anon key (Dashboard > Project Settings > API > Project API keys > anon)
VITE_SUPABASE_ANON_KEY=

# Optional: project ref for Supabase CLI (Dashboard URL has /project/<project-ref>)
SUPABASE_PROJECT_REF=

# Optional: DB password for CLI usage
SUPABASE_DB_PASSWORD=

# Optional: personal access token for CLI automation
SUPABASE_ACCESS_TOKEN=

# Optional: service role key for backend scripts only.
# Do not expose this key in frontend.
SUPABASE_SERVICE_ROLE_KEY=

